# ─── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ─── Database (MySQL 8) ────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=echoras
DB_USER=echoras_user
DB_PASS=changeme

# ─── File upload ───────────────────────────────────────────
MAX_FILE_SIZE_MB=50

# ─── Blender (Python rendering service) ───────────────────
BLENDER_PATH=/usr/bin/blender

# ─── Auth (Phase 2) ───────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=24h

# ─── Stripe (Phase 3) ─────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email (Phase 3) ───────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@echoras.fr
SMTP_PASS=changeme
